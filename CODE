Pi = ask_float("Initial reservoir pressure, Pi (psi)", 4000)
Pb = ask_float("Bubble point pressure, Pb (psi)", 3000)
Temperature = ask_float("Reservoir temperature (deg F)", 180)
API = ask_float("Oil API gravity", 35)
GasGravity = ask_float("Gas specific gravity", 0.75)

Area = ask_float("Reservoir area (acres)", 640)
NetPay = ask_float("Net pay thickness (ft)", 50)
