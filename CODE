cw = ask_float("Water compressibility, cw (1/psi)", 3e-6)
cf = ask_float("Formation compressibility, cf (1/psi)", 5e-6)

gas_cap_ratio_m = ask_float("Gas-cap ratio m = gas-cap volume / oil-zone volume", 0.10)
