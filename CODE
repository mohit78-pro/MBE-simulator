# ==========================================================
# 2. BASIC RESERVOIR VOLUMETRICS
# ==========================================================

OilGravity = 141.5 / (API + 131.5)

# Volumetric OOIP in stock tank barrels:
# N = 7758 Ah phi (1-Swi) / Boi
OOIP_TRUE = 7758 * Area * NetPay * Porosity * (1 - Swi) / Boi


# ==========================================================
# 3. PVT CORRELATIONS
# ==========================================================

def standing_bubble_point(rs, api, temp_f, gas_gravity):
    return 18.2 * (((rs / gas_gravity) ** 0.83) *
                   (10 ** (0.00091 * temp_f - 0.0125 * api)) - 1.4)


def solution_gor(pressure):
    pressure = np.asarray(pressure, dtype=float)
    rs = GasGravity * (
        (pressure * (10 ** (0.0125 * API))) /
        (18 * (10 ** (0.00091 * Temperature)))
    ) ** 1.2048
    return np.where(pressure >= Pb, Rsi, np.minimum(rs, Rsi))


def oil_fvf(pressure):
    pressure = np.asarray(pressure, dtype=float)
    rs = solution_gor(pressure)
    co_above_pb = 1.5e-5

    bo_saturated = 0.9759 + 0.00012 * (
        rs * np.sqrt(GasGravity / OilGravity) + 1.25 * Temperature
    ) ** 1.2

    bo_undersaturated = Boi * np.exp(-co_above_pb * (pressure - Pb))
    return np.where(pressure >= Pb, bo_undersaturated, bo_saturated)


def water_fvf(pressure):
    pressure = np.asarray(pressure, dtype=float)
    dvwp = (
        -1.95301e-9 * pressure * Temperature
        - 1.72834e-13 * (pressure ** 2) * Temperature
        - 3.58922e-7 * pressure
        - 2.25341e-10 * (pressure ** 2)
    )
    dvwt = -1.0001e-2 + 1.33391e-4 * Temperature + 5.50654e-7 * (Temperature ** 2)
    return (1 + dvwp) * (1 + dvwt)


def z_factor(pressure):
    pressure = np.asarray(pressure, dtype=float)
    z = 1 - 0.00003 * (4000 - pressure)
    return np.maximum(z, 0.75)


def gas_fvf(pressure):
    pressure = np.asarray(pressure, dtype=float)
    return 0.005035 * z_factor(pressure) * (Temperature + 460) / pressure


# ==========================================================
# 4. SYNTHETIC BUT MATERIAL-BALANCE-CONSISTENT HISTORY
# ==========================================================

month = np.arange(history_months + 1)
time_fraction = month / history_months

aquifer_strength = np.clip(aquifer_strength, 0, 1)
gas_cap_ratio_m = max(gas_cap_ratio_m, 0)

base_pressure_drop = 1800
aquifer_support = 850 * aquifer_strength
gas_cap_support = 350 * np.tanh(1.6 * gas_cap_ratio_m)
final_pressure_drop = max(550, base_pressure_drop - aquifer_support - gas_cap_support)

pressure = Pi - final_pressure_drop * (1 - np.exp(-2.2 * time_fraction)) / (1 - np.exp(-2.2))
pressure = np.maximum(pressure, 900)
pressure[0] = Pi

Rs = solution_gor(pressure)
Bo = oil_fvf(pressure)
Bw = water_fvf(pressure)
Bg = gas_fvf(pressure)
Bgi = gas_fvf(np.array([Pi]))[0]

ce = (cw * Swi + cf) / (1 - Swi)
delta_p = Pi - pressure

Eo = (Bo - Boi) + (Rsi - Rs) * Bg
Efw = Boi * ce * delta_p
Eg = Boi * ((Bg / Bgi) - 1)

aquifer_constant = OOIP_TRUE * Boi * 1.25
We = aquifer_strength * aquifer_constant * (delta_p / Pi) ** 1.15

Et_true = Eo + gas_cap_ratio_m * Eg + Efw
F_clean = OOIP_TRUE * Et_true + We

# Add small realistic measurement noise, but keep the first point exact.
rng = np.random.default_rng(42)
noise = rng.normal(0, 0.012, len(F_clean))
noise[0] = 0
F = np.maximum(F_clean * (1 + noise), 0)

# Split total withdrawal into oil, water, and gas production in a consistent way.
oil_share = 0.56 - 0.10 * aquifer_strength
Np = oil_share * F / np.maximum(Bo, 1e-9)
Np[0] = 0
Np = np.maximum.accumulate(Np)

Wp = aquifer_strength * (0.10 + 0.32 * time_fraction ** 1.8) * Np
Wp[0] = 0
Wp = np.maximum.accumulate(Wp)

free_gas_term = F - Np * Bo - Wp * Bw
Gp = Np * Rs + free_gas_term / np.maximum(Bg, 1e-12)

# Keep gas cumulative physically reasonable and monotonic.
Gp = np.maximum(Gp, Np * Rs * 1.01)
Gp[0] = 0
Gp = np.maximum.accumulate(Gp)

oil_rate = np.diff(Np, prepend=0) / 30
gas_rate = np.diff(Gp, prepend=0) / 30
water_rate = np.diff(Wp, prepend=0) / 30

oil_rate[0] = 0
gas_rate[0] = 0
water_rate[0] = 0

GOR = np.divide(gas_rate, oil_rate, out=np.zeros_like(gas_rate), where=oil_rate > 0)
water_cut = 100 * np.divide(water_rate, oil_rate + water_rate,
                            out=np.zeros_like(water_rate), where=(oil_rate + water_rate) > 0)


# ==========================================================
# 5. OOIP ESTIMATION BY HAVLENA-ODEH LINEAR REGRESSION
# ==========================================================

def regression_through_origin(x, y):
    mask = (np.isfinite(x)) & (np.isfinite(y)) & (x > 1e-9)
    x = x[mask]
    y = y[mask]
    slope = np.sum(x * y) / np.sum(x * x)
    y_pred = slope * x
    residual = y - y_pred
    ss_res = np.sum(residual ** 2)
    ss_tot = np.sum((y - np.mean(y)) ** 2)
    r2 = 1 - ss_res / ss_tot if ss_tot > 0 else np.nan
    mape = np.mean(np.abs(residual / np.maximum(y, 1e-9))) * 100
    return slope, r2, mape, mask


F_observed = Np * Bo + (Gp - Np * Rs) * Bg + Wp * Bw

Et_solution_gas = Eo + Efw
Et_gas_cap = Eo + gas_cap_ratio_m * Eg + Efw
Et_water_drive = Eo + gas_cap_ratio_m * Eg + Efw

N_solution_gas, r2_sg, mape_sg, mask_sg = regression_through_origin(
    Et_solution_gas, F_observed
)
N_gas_cap, r2_gc, mape_gc, mask_gc = regression_through_origin(
    Et_gas_cap, F_observed
)
N_water_drive, r2_wd, mape_wd, mask_wd = regression_through_origin(
    Et_water_drive, F_observed - We
)

model_table = pd.DataFrame({
    "Model": ["Solution Gas Drive", "Gas Cap Drive", "Water Drive"],
    "Estimated_OOIP_STB": [N_solution_gas, N_gas_cap, N_water_drive],
    "Estimated_OOIP_MMSTB": [N_solution_gas / 1e6, N_gas_cap / 1e6, N_water_drive / 1e6],
    "R2": [r2_sg, r2_gc, r2_wd],
    "MAPE_percent": [mape_sg, mape_gc, mape_wd]
})

best_row = model_table.sort_values(["MAPE_percent", "R2"], ascending=[True, False]).iloc[0]
OOIP_EST = best_row["Estimated_OOIP_STB"]


# ==========================================================
# 6. DRIVE MECHANISM DIAGNOSIS
# ==========================================================

oil_expansion_energy = OOIP_EST * np.maximum(Eo, 0)
gas_cap_energy = OOIP_EST * gas_cap_ratio_m * np.maximum(Eg, 0)
rock_water_energy = OOIP_EST * np.maximum(Efw, 0)
aquifer_energy = np.maximum(We, 0)

final_energy = {
    "Solution Gas Drive": oil_expansion_energy[-1] + rock_water_energy[-1],
    "Gas Cap Drive": gas_cap_energy[-1],
    "Water Drive": aquifer_energy[-1],
}

total_final_energy = sum(final_energy.values())
energy_percent = {k: 100 * v / total_final_energy for k, v in final_energy.items()}

pressure_drop_percent = 100 * (Pi - pressure[-1]) / Pi
gor_increase_percent = 100 * (np.nanmean(GOR[-12:]) - np.nanmean(GOR[1:13])) / max(np.nanmean(GOR[1:13]), 1)
water_cut_final = water_cut[-1]

scores = {
    "Solution Gas Drive": 0.45 * energy_percent["Solution Gas Drive"]
                          + 0.35 * pressure_drop_percent
                          + 0.20 * max(gor_increase_percent, 0),
    "Gas Cap Drive": 0.65 * energy_percent["Gas Cap Drive"]
                     + 0.35 * max(gor_increase_percent, 0),
    "Water Drive": 0.70 * energy_percent["Water Drive"]
                   + 0.30 * water_cut_final,
}

diagnosed_drive = max(scores, key=scores.get)
confidence = scores[diagnosed_drive] / sum(scores.values()) * 100


# ==========================================================
# 7. FORECAST USING DIAGNOSED DRIVE MECHANISM
# ==========================================================

forecast_months = forecast_years * 12
future_month = np.arange(1, forecast_months + 1)
last_month = month[-1]

if diagnosed_drive == "Water Drive":
    pressure_decline_per_month = 3.5
    oil_decline_annual = 0.09
    water_growth_annual = 0.11
    gor_growth_annual = 0.01
elif diagnosed_drive == "Gas Cap Drive":
    pressure_decline_per_month = 7.0
    oil_decline_annual = 0.13
    water_growth_annual = 0.03
    gor_growth_annual = 0.12
else:
    pressure_decline_per_month = 11.0
    oil_decline_annual = 0.18
    water_growth_annual = 0.04
    gor_growth_annual = 0.16

monthly_oil_decline = oil_decline_annual / 12
monthly_water_growth = water_growth_annual / 12
monthly_gor_growth = gor_growth_annual / 12

forecast_pressure = np.maximum(pressure[-1] - pressure_decline_per_month * future_month, 700)
forecast_oil_rate = oil_rate[-1] * np.exp(-monthly_oil_decline * future_month)
forecast_water_rate = water_rate[-1] * np.exp(monthly_water_growth * future_month)
forecast_gor = GOR[-1] * np.exp(monthly_gor_growth * future_month)
forecast_gas_rate = forecast_oil_rate * forecast_gor

active = forecast_oil_rate >= economic_oil_rate
if active.any():
    cutoff = np.where(active)[0][-1] + 1
else:
    cutoff = 0

forecast_pressure = forecast_pressure[:cutoff]
forecast_oil_rate = forecast_oil_rate[:cutoff]
forecast_water_rate = forecast_water_rate[:cutoff]
forecast_gas_rate = forecast_gas_rate[:cutoff]
forecast_gor = forecast_gor[:cutoff]
future_month = future_month[:cutoff]

forecast_Np = Np[-1] + np.cumsum(forecast_oil_rate * 30)
forecast_Gp = Gp[-1] + np.cumsum(forecast_gas_rate * 30)
forecast_Wp = Wp[-1] + np.cumsum(forecast_water_rate * 30)
forecast_RF = 100 * forecast_Np / OOIP_EST
forecast_water_cut = 100 * forecast_water_rate / (forecast_oil_rate + forecast_water_rate)


