def ask_float(prompt, default):
    """Ask for a number. Press Enter to keep the default."""
    if not ASK_USER_INPUTS:
        return float(default)

    value = input(f"{prompt} [{default}]: ").strip()
    if value == "":
        return float(default)
    return float(value)


def ask_int(prompt, default):
    return int(ask_float(prompt, default))


print("\n" + "=" * 72)
print("MATERIAL BALANCE RESERVOIR SIMULATOR")
print("User-input synthetic field data + OOIP estimation + drive diagnosis")
print("=" * 72)
